#!/bin/bash
# setup-pe-networking.sh — Generated by Ansible for PE{{ node_id + 1 }} (node {{ node_id }})
# Creates namespaces, veths, VRFs, VXLAN bridge, and starts FRR containers.
set -euo pipefail

FABRIC_IF="{{ fabric_if }}"
FRR_IMAGE="{{ frr_image }}"

echo "=== Setting up PE{{ node_id + 1 }} (node {{ node_id }}) | fabric=$FABRIC_IF ==="

# ── Clean up any previous run ─────────────────────────────────
echo ">>> Cleaning up previous state..."
podman rm -f frr-pe-router frr-l2-vxlan 2>/dev/null || true
ip netns del pe-router 2>/dev/null || true
ip netns del l2-vxlan 2>/dev/null || true
ip link del ve-ovn-pe-cmn 2>/dev/null || true
ip link del ve-host-pe-cmn 2>/dev/null || true
ip link del ve-home-l2-br 2>/dev/null || true
ip link del ve-l2-pe-cmn 2>/dev/null || true
sleep 1

# ── pe-router namespace ───────────────────────────────────────
echo ">>> Building pe-router namespace..."
ip netns add pe-router

ip netns exec pe-router ip link set lo up
ip netns exec pe-router ip addr add {{ isis_lo }} dev lo

ip netns exec pe-router sysctl -qw \
  net.ipv6.conf.all.seg6_enabled=1 \
  net.ipv6.conf.all.forwarding=1 \
  net.ipv4.conf.all.forwarding=1 \
  net.ipv4.conf.all.rp_filter=0 \
  net.ipv4.conf.default.rp_filter=0 \
  net.ipv6.seg6_flowlabel=1

# SRv6 source-address dummy
ip netns exec pe-router ip link add sr0 type dummy
ip netns exec pe-router ip link set sr0 up

# VRFs
ip netns exec pe-router ip link add CMN type vrf table 4
ip netns exec pe-router ip link set CMN up
ip netns exec pe-router ip link add EDN type vrf table 2
ip netns exec pe-router ip link set EDN up
ip netns exec pe-router sysctl -qw net.vrf.strict_mode=1

# CMN loopback
ip netns exec pe-router ip link add lo-cmn type dummy
ip netns exec pe-router ip link set lo-cmn master CMN
ip netns exec pe-router ip link set lo-cmn down
ip netns exec pe-router ip link set lo-cmn up
ip netns exec pe-router ip addr add {{ cmn_lo_v4 }} dev lo-cmn

# Move fabric NIC into pe-router
ip link set "$FABRIC_IF" netns pe-router
ip netns exec pe-router ip link set "$FABRIC_IF" mtu 9000
ip netns exec pe-router ip link set "$FABRIC_IF" up

ip netns exec pe-router sysctl -qw \
  net.ipv4.conf."$FABRIC_IF".rp_filter=0 \
  net.ipv4.conf.CMN.rp_filter=0 \
  net.ipv4.conf.EDN.rp_filter=0 \
  net.ipv4.conf.lo.rp_filter=0 \
  net.ipv4.conf.lo-cmn.rp_filter=0 \
  net.ipv4.conf.sr0.rp_filter=0 \
  net.ipv6.conf."$FABRIC_IF".seg6_enabled=1

# SRv6 locator policy routing
ip netns exec pe-router ip -6 rule add to fd00::/16 lookup 254 pref 999
ip netns exec pe-router ip -6 rule add to fd01::/16 lookup 254 pref 999

# ── Veth: default ns ↔ pe-router CMN (direct L3 path) ────────
ip link add ve-ovn-pe-cmn mtu 8900 type veth peer name ve-pe-cmn-ovn
ip link set ve-pe-cmn-ovn netns pe-router
ip netns exec pe-router ip link set ve-pe-cmn-ovn mtu 8900
ip netns exec pe-router ip link set ve-pe-cmn-ovn master CMN
ip netns exec pe-router ip link set ve-pe-cmn-ovn down
ip netns exec pe-router ip link set ve-pe-cmn-ovn up
ip netns exec pe-router ip addr add {{ ve_ovn_pe }} dev ve-pe-cmn-ovn
ip link set ve-ovn-pe-cmn up
ip addr add {{ ve_ovn_def }} dev ve-ovn-pe-cmn

# ── Veth: Host ↔ pe-router CMN ────────────────────────────────
ip link add ve-host-pe-cmn mtu 8900 type veth peer name ve-pe-cmn-host
ip link set ve-pe-cmn-host netns pe-router
ip netns exec pe-router ip link set ve-pe-cmn-host mtu 8900
ip netns exec pe-router ip link set ve-pe-cmn-host master CMN
ip netns exec pe-router ip link set ve-pe-cmn-host down
ip netns exec pe-router ip link set ve-pe-cmn-host up
ip netns exec pe-router ip addr add {{ ve_host_pe }} dev ve-pe-cmn-host
ip link set ve-host-pe-cmn up
ip addr add {{ ve_host_def }} dev ve-host-pe-cmn

ip netns exec pe-router sysctl -qw \
  net.ipv4.conf.ve-pe-cmn-ovn.rp_filter=0 \
  net.ipv4.conf.ve-pe-cmn-host.rp_filter=0

# ── l2-vxlan namespace ────────────────────────────────────────
echo ">>> Building l2-vxlan namespace..."
ip netns add l2-vxlan
ip netns exec l2-vxlan ip link set lo up

# ── Veth: l2-vxlan ↔ pe-router CMN (VTEP reachability) ────────
ip link add ve-l2-pe-cmn mtu 9000 type veth peer name ve-pe-cmn-l2
ip link set ve-l2-pe-cmn netns l2-vxlan
ip link set ve-pe-cmn-l2 netns pe-router
ip netns exec pe-router ip link set ve-pe-cmn-l2 mtu 9000
ip netns exec pe-router ip link set ve-pe-cmn-l2 master CMN
ip netns exec pe-router ip link set ve-pe-cmn-l2 down
ip netns exec pe-router ip link set ve-pe-cmn-l2 up
ip netns exec pe-router ip addr add {{ ve_l2_pe }} dev ve-pe-cmn-l2
ip netns exec l2-vxlan ip link set ve-l2-pe-cmn mtu 9000
ip netns exec l2-vxlan ip link set ve-l2-pe-cmn up
ip netns exec l2-vxlan ip addr add {{ ve_l2 }} dev ve-l2-pe-cmn

ip netns exec pe-router sysctl -qw net.ipv4.conf.ve-pe-cmn-l2.rp_filter=0

# Default route in l2-vxlan → pe-router CMN
ip netns exec l2-vxlan ip route add default via {{ l2_gw }}

# ── VLAN-aware bridge ─────────────────────────────────────────
ip netns exec l2-vxlan ip link add br0 type bridge \
  vlan_filtering 1 vlan_default_pvid 0
ip netns exec l2-vxlan ip link set br0 mtu 8854
ip netns exec l2-vxlan ip link set br0 up
ip netns exec l2-vxlan bridge vlan add vid 30 dev br0 self

# ── VXLAN device (VNI 330) ────────────────────────────────────
ip netns exec l2-vxlan ip link add vxlan0 type vxlan \
  id 330 dstport 4789 local {{ vtep }} ttl 64 \
  nolearning udpcsum udp6zerocsumrx
ip netns exec l2-vxlan ip link set vxlan0 addrgenmode none
ip netns exec l2-vxlan ip link set vxlan0 master br0
ip netns exec l2-vxlan ip link set vxlan0 mtu 8854
ip netns exec l2-vxlan ip link set vxlan0 up

ip netns exec l2-vxlan bridge link set dev vxlan0 \
  neigh_suppress on learning off
ip netns exec l2-vxlan bridge vlan add dev vxlan0 vid 30 pvid untagged master

# ── VLAN 30 sub-interface + anycast gateway ───────────────────
ip netns exec l2-vxlan ip link add vlan30 link br0 type vlan id 30
ip netns exec l2-vxlan ip link set vlan30 mtu 8804
ip netns exec l2-vxlan ip link set vlan30 up

ip netns exec l2-vxlan ip link add vlan-30-ednagw \
  link vlan30 type macvlan mode private
ip netns exec l2-vxlan ip link set vlan-30-ednagw address aa:dd:cc:00:ff:ee
ip netns exec l2-vxlan ip link set vlan-30-ednagw up
ip netns exec l2-vxlan ip addr add 10.55.99.1/26 dev vlan-30-ednagw

ip netns exec l2-vxlan bridge fdb add aa:dd:cc:00:ff:ee dev br0 self local

# ── Veth: default ns ↔ l2-vxlan bridge (machine network) ──────
ip link add ve-home-l2-br mtu 8800 type veth peer name ve-l2-br-home
ip link set ve-l2-br-home netns l2-vxlan
ip netns exec l2-vxlan ip link set ve-l2-br-home master br0
ip netns exec l2-vxlan ip link set ve-l2-br-home mtu 8800
ip netns exec l2-vxlan ip link set ve-l2-br-home up
ip netns exec l2-vxlan bridge vlan add dev ve-l2-br-home vid 30 \
  pvid untagged master

# ── l2-vxlan sysctls ──────────────────────────────────────────
ip netns exec l2-vxlan sysctl -qw \
  net.ipv4.conf.all.rp_filter=0 \
  net.ipv4.conf.default.rp_filter=0 \
  net.ipv4.conf.all.accept_local=1 \
  net.ipv4.conf.all.proxy_arp=1 \
  net.ipv4.conf.br0.proxy_arp=1 \
  net.ipv4.conf.all.send_redirects=0

for dev in br0 vxlan0 vlan30 vlan-30-ednagw ve-l2-br-home ve-l2-pe-cmn; do
  ip netns exec l2-vxlan ethtool -K "$dev" rx off tx off 2>/dev/null || true
done

# ── Machine network in default namespace ──────────────────────
echo ">>> Configuring machine network..."
ip link set ve-home-l2-br mtu 8800
ip link set ve-home-l2-br up
ip addr add {{ machine_v4 }} dev ve-home-l2-br

sysctl -qw \
  net.ipv6.conf.all.seg6_enabled=1 \
  net.ipv4.conf.all.forwarding=1 \
  net.ipv6.conf.all.forwarding=1 \
  net.ipv4.conf.all.rp_filter=0

# ── Start FRR containers ──────────────────────────────────────
echo ">>> Starting FRR containers..."

podman run -d --name frr-pe-router \
  --hostname {{ inventory_hostname }}-pe-router \
  --network=ns:/run/netns/pe-router \
  --privileged \
  -v /etc/frr/pe-router:/etc/frr \
  "$FRR_IMAGE"

podman run -d --name frr-l2-vxlan \
  --hostname {{ inventory_hostname }}-l2-vxlan \
  --network=ns:/run/netns/l2-vxlan \
  --privileged \
  -v /etc/frr/l2-vxlan:/etc/frr \
  "$FRR_IMAGE"

echo ""
echo "=== PE{{ node_id + 1 }} setup complete ==="
echo "  Machine network IP: {{ machine_v4 }}"
echo "  pe-router FRR:  sudo podman exec frr-pe-router vtysh"
echo "  l2-vxlan FRR:   sudo podman exec frr-l2-vxlan vtysh"
